# SerenDipity — Environment Variables
# Copy this file to .env and fill in your values

# JWT secret key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=change-me-to-a-random-string

# Database (SQLite file path, or PostgreSQL URL)
# DATABASE_URL=sqlite+aiosqlite:///./serendipity.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost/serendipity

# Google OAuth — get these from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Email SMTP — for sending magic links
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# App URL (used in magic link emails)
FRONTEND_URL=http://localhost:8000

# Debug mode
DEBUG=false
